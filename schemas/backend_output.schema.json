{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://product-dev-agents.local/schemas/backend_output.schema.json",
  "title": "Backend Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apis",
    "api_contract",
    "security_review",
    "performance_risks",
    "handoff",
    "issues"
  ],
  "properties": {
    "apis": { "type": "array" },
    "api_contract": {
      "allOf": [
        { "$ref": "common.schema.json#/$defs/contract" },
        {
          "type": "object",
          "required": ["openapi"],
          "properties": {
            "openapi": {}
          }
        }
      ]
    },
    "security_review": { "type": "object" },
    "performance_risks": { "type": "array" },
    "handoff": { "$ref": "common.schema.json#/$defs/handoff" },
    "issues": { "type": "array", "items": { "$ref": "issue.schema.json" } }
  }
}
